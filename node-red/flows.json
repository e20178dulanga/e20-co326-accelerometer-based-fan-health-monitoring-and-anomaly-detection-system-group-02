    {
        "id": "bff6283d0b3f506e",
        "type": "ui_template",
        "z": "480eabb870c38958",
        "group": "6e9ea93255d69f23",
        "name": "alert",
        "order": 0,
        "width": "6",
        "height": "6",
        "format": "<div id=\"statusBox\" style=\"\n    font-size:28px;\n    font-weight:bold;\n    border-radius:12px;\n    text-align:center;\n    border:2px solid {{msg.color}};\n    background:{{msg.bg}};\n    color:{{msg.color}};\n    transition: all 0.3s ease;\n\n    height:180px;\n\n    display:flex;\n    align-items:center;\n    justify-content:center;\n\n     \">\n    {{msg.payload}}\n</div>\n\n<script>\n    (function(scope) {\n\n    let blink = null;\n\n    scope.$watch('msg', function(msg) {\n\n        if (!msg) return;\n\n        const box = document.getElementById(\"statusBox\");\n\n        // stop previous blinking\n        if (blink) {\n            clearInterval(blink);\n            blink = null;\n        }\n\n        // ANOMALY → flashing\n        if (msg.flash === true) {\n\n            let visible = true;\n\n            blink = setInterval(function () {\n                if (!box) return;\n\n                box.style.visibility = visible ? \"hidden\" : \"visible\";\n                visible = !visible;\n            }, 500);\n\n        } else {\n            // NORMAL → always visible\n            if (box) box.style.visibility = \"visible\";\n        }\n    });\n\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1250,
        "y": 540,
        "wires": [
            []
        ]
    },
